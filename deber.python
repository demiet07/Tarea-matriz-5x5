# Ejercicio 1: Imprimir los números del 1 al 5 utilizando ciclo de repeticio 
# Manuel Damian Ortega Japon 
# semana 8 paralelo G
i = 1
print(" "*40)
print("Ejercicio 1: Imprimir los números del 1 al 5 utilizando ciclo de repeticio")

while i <= 5:
    print(i)
    i = i + 1
print("->finalizavion del programa ")